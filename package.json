{
  "name": "@inradius/solid-wc-utils-monorepo",
  "private": true,
  "author": "Travis Stroud <travis.unfasten577@travisstroud.me>",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "postinstall": "turbo run build --filter=./packages/*",
    "release": "turbo run build && changeset publish",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@inradius/solid-wc-utils-config": "workspace:*",
    "@vitest/ui": "^2.1.9",
    "eslint": "^10.0.3",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
