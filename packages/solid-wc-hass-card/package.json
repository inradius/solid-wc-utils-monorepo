{
  "name": "@inradius/solid-wc-hass-card",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:app:solid && pnpm build:app:wc",
    "build:app:solid": "vite build builds/app",
    "build:app:wc": "vite build builds/wc",
    "clean": "rimraf dist",
    "dev": "vite builds/app --host --open",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@inradius/solid-wc-css-mixin": "workspace:*",
    "@inradius/solid-wc-hass-mixin": "workspace:*",
    "@inradius/solid-wc-utils-config": "workspace:*",
    "@solid-primitives/destructure": "^0.2.2",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.0",
    "component-register": "^0.8.8",
    "custom-card-helpers": "^2.0.0",
    "solid-devtools": "^0.34.5",
    "solid-element": "^1.9.1",
    "solid-js": "^1.9.11",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-replace": "^0.1.1",
    "vite-plugin-solid": "2.11.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.0"
  }
}
